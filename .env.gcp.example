DATABASE_URL=postgresql+psycopg2://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME
JWT_SECRET_KEY=replace-with-secret-manager-value
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REMEMBER_ME_EXPIRE_DAYS=30
FRONTEND_ORIGIN=https://your-frontend-domain.example
FRONTEND_ORIGINS=https://your-frontend-domain.example,http://localhost:3000
ENVIRONMENT=production
GEMINI_API_KEY=replace-with-secret-manager-value
GEMINI_MODEL=gemini-2.5-flash
